# ─── App ────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://jansamaadhan.in
NEXT_PUBLIC_APP_NAME=JanSamaadhan

# ─── Database (Vercel Postgres / Neon) ──────────────────────────
# Auto-populated by Vercel when you connect a Postgres database under
# Project → Storage. For local dev, run: vercel env pull .env.local
DATABASE_URL=postgresql://user:password@host/jansamaadhan?sslmode=require&pgbouncer=true
DATABASE_URL_UNPOOLED=postgresql://user:password@host/jansamaadhan?sslmode=require

# ─── OTP / SMS — Msg91 (primary) ────────────────────────────────
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_OTP_TEMPLATE_ID=your_template_id
MSG91_SENDER_ID=JANSAM

# ─── Payments — Razorpay ────────────────────────────────────────
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ─── Storage — Cloudflare R2 ────────────────────────────────────
# S3-compatible API via @aws-sdk/client-s3 pointed at R2's endpoint.
# Endpoint: https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=jansamaadhan-docs
# Optional: public URL if R2 public access / custom domain is enabled
R2_PUBLIC_URL=https://docs.jansamaadhan.in

# ─── Session ────────────────────────────────────────────────────
# Minimum 32 random chars — generate with: openssl rand -base64 32
# (Not currently used — session cookie is plain role:phone. Swap in
# Iron Session or a signed JWT before going to production.)
SESSION_SECRET=replace_with_32_plus_random_chars_here

# ─── WhatsApp ───────────────────────────────────────────────────
NEXT_PUBLIC_WA_NUMBER=918000000000

# ─── Analytics (optional) ───────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
